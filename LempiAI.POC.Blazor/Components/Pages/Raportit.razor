@page "/raportit"
@rendermode InteractiveServer
@using LempiAI.POC.Blazor.Models
@using LempiAI.POC.Blazor.Services
@inject ApiService ApiService

<div class="container mt-5">
    <h1>📊 Raportit ja Parannusehdotukset</h1>
    <hr>

    <!-- Blazor-tabit -->
    <ul class="nav nav-tabs">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "reports" ? "active" : "")"
                    @onclick='() => SetTab("reports")'>
                Raportit
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "improvements" ? "active" : "")"
                    @onclick='() => SetTab("improvements")'>
                Parannusehdotukset
            </button>
        </li>
    </ul>





    <div class="mt-3">

        @* -------------------- RAPORTIT -------------------- *@
        @if (activeTab == "reports")
        {
            @if (isLoadingReports)
            {
                <div class="alert alert-info">📥 Ladataan raportteja...</div>
            }
            else if (reportError != null)
            {
                <div class="alert alert-danger"><strong>❌ Virhe:</strong> @reportError</div>
            }
            else if (reports == null || reports.Count == 0)
            {
                <div class="alert alert-warning">⚠️ Ei raportteja.</div>
            }
            else
            {
                <div class="card">
                    <div class="card-header bg-warning text-dark">
                        <h5>AI-Agentin Raportit (@reports.Count kpl)</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Agentti</th>
                                    <th>Otsikko</th>
                                    <th>Tyyppi</th>
                                    <th>Luotu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in reports)
                                {
                                    <tr>
                                        <td>@r.Id</td>
                                        <td><strong>@r.AgentName</strong></td>
                                        <td>@r.Title</td>
                                        <td><span class="badge bg-info">@r.ReportType</span></td>
                                        <td>@r.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }

        @* -------------------- PARANNUSEHDOTUKSET -------------------- *@
        @if (activeTab == "improvements")
        {
            @if (isLoadingImprovements)
            {
                <div class="alert alert-info">📥 Ladataan parannusehdotuksia...</div>
            }
            else if (improvementError != null)
            {
                <div class="alert alert-danger"><strong>❌ Virhe:</strong> @improvementError</div>
            }
            else if (improvements == null || improvements.Count == 0)
            {
                <div class="alert alert-warning">⚠️ Ei parannusehdotuksia.</div>
            }
            else
            {
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5>Prosessien Parannusehdotukset (@improvements.Count kpl)</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Otsikko</th>
                                    <th>Prosessialue</th>
                                    <th>Vaikutustaso</th>
                                    <th>Status</th>
                                    <th>Luotu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var i in improvements)
                                {
                                    <tr>
                                        <td>@i.Id</td>
                                        <td>@i.Title</td>
                                        <td>@i.ProcessArea</td>
                                        <td>
                                            @if (i.ImpactLevel == "High")
                                            {
                                                <span class="badge bg-danger">@i.ImpactLevel</span>
                                            }
                                            else if (i.ImpactLevel == "Medium")
                                            {
                                                <span class="badge bg-warning text-dark">@i.ImpactLevel</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@i.ImpactLevel</span>
                                            }
                                        </td>
                                        <td>
                                            @if (i.Status == "Implemented")
                                            {
                                                <span class="badge bg-success">@i.Status</span>
                                            }
                                            else if (i.Status == "In Progress")
                                            {
                                                <span class="badge bg-warning text-dark">@i.Status</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@i.Status</span>
                                            }
                                        </td>
                                        <td>@i.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private string activeTab = "reports";

    private List<AgentReport>? reports;
    private List<ProcessImprovement>? improvements;

    private string? reportError;
    private string? improvementError;

    private bool isLoadingReports = true;
    private bool isLoadingImprovements = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadReports();
        await LoadImprovements();
    }

    private void SetTab(string tab)
    {
        activeTab = tab;
    }

    private async Task LoadReports()
    {
        try
        {
            isLoadingReports = true;
            reportError = null;
            reports = await ApiService.GetAgentReportsAsync();
        }
        catch (Exception ex)
        {
            reportError = $"Virhe ladattaessa raportteja: {ex.Message}";
        }
        finally
        {
            isLoadingReports = false;
        }
    }

    private async Task LoadImprovements()
    {
        try
        {
            isLoadingImprovements = true;
            improvementError = null;
            improvements = await ApiService.GetImprovementsAsync();
        }
        catch (Exception ex)
        {
            improvementError = $"Virhe ladattaessa parannusehdotuksia: {ex.Message}";
        }
        finally
        {
            isLoadingImprovements = false;
        }
    }
}
